+        reply2 = " ".join(resp2.get("reply", []))
+        chat_log += f"{npc2_id}: {reply2}\n"
+        print(f"[{npc2_id}]: {reply2}")
+
+        # 다음 턴을 위해 메시지 교체
+        current_message = f"[상대방의 말: '{reply2}']\n이 말에 이어서 대답해."
+
+    print("\n[서버 백그라운드: 대화를 바탕으로 오늘의 소문을 요약합니다...]")
